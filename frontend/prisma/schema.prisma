datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Item {
  registrationId String         @id
  ownerAddress   String
  name           String
  brand          String?
  serial         String?
  reward         String?
  contactInfo    String?
  instructions   String?
  itemHash       String
  status         String
  category       String         @default("Other")
  alternateContact String?
  receiptData    String?        // Base64 encoded item receipt (stored off-chain)
  secrets        String?        // Serial number, IMEI, or distinguishing marks (private off-chain)
  passphrase     String?        // Owner's custom passphrase or PIN (private off-chain)
  image          String?        // Base64 encoded item image (optional)
  rewardType     String         @default("custom") // custom, none, undisclosed
  isActiveQr     Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  reports        FinderReport[]

  @@index([ownerAddress])
}

model FinderReport {
  reportId       String   @id @default(uuid())
  registrationId String
  item           Item     @relation(fields: [registrationId], references: [registrationId], onDelete: Cascade)
  message        String
  contactInfo    String?
  location       String?
  photo          String?  // Base64 compressed image data URL
  createdAt      DateTime @default(now())
}

model User {
  walletAddress String   @id
  fullName      String
  username      String   @unique
  subscriptionActive Boolean @default(false)
  emailNotifications Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id             String   @id @default(uuid())
  ownerAddress   String
  registrationId String
  type           String   // "scan", "report", "recovered"
  message        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([ownerAddress])
}

model PushSubscription {
  id             String   @id @default(uuid())
  ownerAddress   String
  endpoint       String   @unique
  keys           String   // Stringified keys JSON: { p256dh: string, auth: string }
  createdAt      DateTime @default(now())

  @@index([ownerAddress])
}
